          "trigger": ["menu"],
          "menu": ["copy", "paste", "delete"]
        },
        "controlsByKey": { "trigger": ["menu"] },
        "ownerByKey": { "menu": "trigger" }
      },
      "state": {
        "activeKey": "copy",
        "expandedKeys": ["trigger"],
        "disabledKeys": ["paste"]
      }
    }
  },
  "alert": {
    "component": "Alert",
