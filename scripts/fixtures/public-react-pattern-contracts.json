          { "rowKey": "row", "columnKey": "name", "cellKey": "name" },
          { "rowKey": "row", "columnKey": "value", "cellKey": "value" }
        ]
      },
      "state": {
        "rowIndexByKey": { "row": 1, "name": 1, "value": 1 },
        "columnIndexByKey": { "name": 1, "value": 2 },
        "rowCount": 1,
        "colCount": 2
