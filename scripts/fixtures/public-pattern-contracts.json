{
  "schemaVersion": 1,
  "treeview": {
    "options": {
      "focusStrategy": "rovingTabIndex",
      "selectionMode": "multiple",
      "itemClickAction": "select"
    },
    "data": {
      "items": {
        "docs": { "label": "Docs" },
        "overview": { "label": "Overview" },
        "api": { "label": "API" },
        "settings": { "label": "Settings" }
      },
      "relations": {
        "rootKeys": ["docs", "settings"],
        "childrenByKey": { "docs": ["overview", "api"] }
      },
      "state": {
        "activeKey": "docs",
        "selectedKeys": ["overview"],
        "expandedKeys": ["docs"],
        "levelByKey": { "docs": 1, "overview": 2, "api": 2, "settings": 1 },
        "posInSetByKey": { "docs": 1, "overview": 1, "api": 2, "settings": 2 },
        "setSizeByKey": { "docs": 2, "overview": 2, "api": 2, "settings": 2 }
      },
      "refs": { "label": "Documentation tree" }
    }
  },
  "grid": {
    "options": {
      "focusStrategy": "rovingTabIndex",
      "selectionMode": "multiple"
    },
    "data": {
      "items": {
        "row-1": { "label": "Row 1" },
        "row-2": { "label": "Row 2" },
        "name": { "label": "Name" },
        "status": { "label": "Status" },
        "r1-name": { "label": "Alpha" },
        "r1-status": { "label": "Ready" },
        "r2-name": { "label": "Beta" },
        "r2-status": { "label": "Blocked" }
      },
      "relations": {
        "rowKeys": ["row-1", "row-2"],
        "columnKeys": ["name", "status"],
        "cells": [
          { "rowKey": "row-1", "columnKey": "name", "cellKey": "r1-name" },
          { "rowKey": "row-1", "columnKey": "status", "cellKey": "r1-status" },
          { "rowKey": "row-2", "columnKey": "name", "cellKey": "r2-name" },
          { "rowKey": "row-2", "columnKey": "status", "cellKey": "r2-status" }
        ]
      },
      "state": {
        "activeKey": "r1-name",
        "anchorKey": "r1-name",
        "selectedKeys": ["r1-name"],
        "rowIndexByKey": { "r1-name": 1, "r1-status": 1, "r2-name": 2, "r2-status": 2 },
        "columnIndexByKey": { "r1-name": 1, "r1-status": 2, "r2-name": 1, "r2-status": 2 },
        "rowCount": 2,
        "colCount": 2
      },
      "refs": { "label": "Status grid" }
    }
  },
  "menubar": {
    "options": {
      "orientation": "horizontal"
    },
    "data": {
      "items": {
        "file": { "label": "File" },
        "new": { "label": "New" },
        "open": { "label": "Open" },
        "edit": { "label": "Edit" },
        "view": { "label": "View" }
      },
      "relations": {
        "rootKeys": ["file", "edit", "view"],
        "childrenByKey": { "file": ["new", "open"] }
      },
      "state": {
        "activeKey": "file",
        "disabledKeys": ["edit"],
        "expandedKeys": []
      },
      "refs": { "label": "Application menu" }
    }
  },
  "tabs": {
    "options": {
      "orientation": "vertical",
      "activationMode": "automatic",
      "closeable": true
    },
    "data": {
      "items": {
        "tab-overview": { "label": "Overview" },
        "tab-api": { "label": "API" },
        "panel-overview": { "label": "Overview panel" },
        "panel-api": { "label": "API panel" }
      },
      "relations": {
        "rootKeys": ["tab-overview", "tab-api"],
        "controlsByKey": {
          "tab-overview": ["panel-overview"],
          "tab-api": ["panel-api"]
        },
        "ownerByKey": {
          "panel-overview": "tab-overview",
          "panel-api": "tab-api"
        }
      },
      "state": {
        "activeKey": "tab-overview",
        "selectedKeys": ["tab-overview"]
      },
      "refs": { "label": "Documentation tabs" }
    }
  },
  "combobox": {
    "options": {
      "haspopup": "listbox",
      "autocomplete": "list"
    },
    "data": {
      "items": {
        "combobox": { "label": "Search" },
        "alpha": { "label": "Alpha" },
        "beta": { "label": "Beta" }
      },
      "state": {
        "activeKey": "combobox",
        "expandedKeys": [],
        "selectedKeys": []
      },
      "refs": { "label": "Search options" }
    }
  },
  "dialog": {
    "data": {
      "items": {
        "trigger": { "label": "Open dialog", "kind": "dialog" },
        "modal": { "label": "Settings dialog" },
        "title": { "label": "Settings" },
        "description": { "label": "Configure settings" },
        "cancel": { "label": "Cancel" },
        "submit": { "label": "Save" }
      },
      "relations": {
        "rootKeys": ["trigger"],
        "controlsByKey": {
          "trigger": ["modal"],
          "modal": ["description"]
        },
        "ownerByKey": { "modal": "title" }
      },
      "state": {
        "activeKey": "trigger",
        "expandedKeys": ["trigger"]
      },
      "refs": { "initialFocusKey": "cancel" }
    }
  },
  "listbox": {
    "options": {
      "focusStrategy": "ariaActiveDescendant",
      "selectionMode": "multiple",
      "orientation": "vertical",
      "followFocus": true
    },
    "data": {
      "items": {
        "one": { "label": "One" },
        "two": { "label": "Two" },
        "three": { "label": "Three" }
      },
      "relations": {
        "rootKeys": ["one", "two", "three"]
      },
      "state": {
        "activeKey": "one",
        "selectedKeys": ["one"],
        "disabledKeys": ["three"],
        "posInSetByKey": { "one": 1, "two": 2, "three": 3 },
        "setSizeByKey": { "one": 3, "two": 3, "three": 3 }
      },
      "refs": { "label": "Number list" }
    }
  },
  "menuButton": {
    "options": {
      "focusStrategy": "rovingTabIndex"
    },
    "data": {
      "items": {
        "trigger": { "label": "Actions" },
        "menu": { "label": "Actions menu" },
        "copy": { "label": "Copy" },
        "paste": { "label": "Paste" },
        "delete": { "label": "Delete" }
      },
      "relations": {
        "rootKeys": ["copy", "paste", "delete"],
        "childrenByKey": { "trigger": ["copy", "paste", "delete"] },
        "controlsByKey": { "trigger": ["menu"] },
        "ownerByKey": { "menu": "trigger" }
      },
      "state": {
        "activeKey": "copy",
        "expandedKeys": ["trigger"],
        "disabledKeys": ["paste"]
      }
    }
  },
  "treegrid": {
    "options": {
      "focusStrategy": "rovingTabIndex",
      "selectionMode": "multiple"
    },
    "data": {
      "items": {
        "parent": { "label": "Parent" },
        "child": { "label": "Child" },
        "sibling": { "label": "Sibling" },
        "name": { "label": "Name" },
        "status": { "label": "Status" },
        "parent-name": { "label": "Parent name" },
        "parent-status": { "label": "Ready" },
        "child-name": { "label": "Child name" },
        "child-status": { "label": "Queued" },
        "sibling-name": { "label": "Sibling name" },
        "sibling-status": { "label": "Done" }
      },
      "relations": {
        "rootKeys": ["parent", "sibling"],
        "childrenByKey": { "parent": ["child"] },
        "rowKeys": ["parent", "child", "sibling"],
        "columnKeys": ["name", "status"],
        "cells": [
          { "rowKey": "parent", "columnKey": "name", "cellKey": "parent-name" },
          { "rowKey": "parent", "columnKey": "status", "cellKey": "parent-status" },
          { "rowKey": "child", "columnKey": "name", "cellKey": "child-name" },
          { "rowKey": "child", "columnKey": "status", "cellKey": "child-status" },
          { "rowKey": "sibling", "columnKey": "name", "cellKey": "sibling-name" },
          { "rowKey": "sibling", "columnKey": "status", "cellKey": "sibling-status" }
        ]
      },
      "state": {
        "activeKey": "parent-name",
        "anchorKey": "parent-name",
        "selectedKeys": ["parent-name"],
        "expandedKeys": ["parent"],
        "rowIndexByKey": {
          "parent": 1,
          "child": 2,
          "sibling": 3,
          "parent-name": 1,
          "parent-status": 1,
          "child-name": 2,
          "child-status": 2,
          "sibling-name": 3,
          "sibling-status": 3
        },
        "columnIndexByKey": {
          "parent-name": 1,
          "parent-status": 2,
          "child-name": 1,
          "child-status": 2,
          "sibling-name": 1,
          "sibling-status": 2
        },
        "levelByKey": { "parent": 1, "child": 2, "sibling": 1 },
        "rowCount": 3,
        "colCount": 2
      },
      "refs": { "label": "Resource treegrid" }
    }
  }
}
