  "scripts": {
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@interactive-os/aria": ">=0.1.0",
    "react": "^18.0.0 || ^19.0.0"
  },
