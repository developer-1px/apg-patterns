{
  "name": "@interactive-os/interaction",
  "version": "0.0.0",
  "private": true,
  "description": "Incubating interaction ownership primitives for Interactive OS keyboard and focus coordination.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
