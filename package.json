{
  "name": "@interactive-os/apg-treeview-contract",
  "version": "0.0.0",
  "description": "Zod-validated declarative APG treeview MVP contract.",
  "keywords": [
    "aria",
    "wai-aria",
    "apg",
    "treeview",
    "zod",
    "a11y"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./src/kernelBuiltins.ts",
    "./src/patterns/*/definition.ts",
    "./src/patterns/*/navigation.ts",
    "./dist/kernelBuiltins.*",
    "./dist/patterns/*/definition.*",
    "./dist/patterns/*/navigation.*"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "vite --config vite.config.ts",
    "demo": "vite --config vite.config.ts",
    "demo:build": "vite build --config vite.config.ts",
    "demo:preview": "vite preview --config vite.config.ts --host 127.0.0.1",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@interactive-os/collection-navigation": "file:../keyboard-navigation/packages/collection-navigation",
    "@interactive-os/keyboard": "file:../keyboard/packages/keyboard",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.22",
    "jsdom": "^29.1.1",
    "lucide-static": "^1.16.0",
    "postcss": "^8.5.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.18",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
