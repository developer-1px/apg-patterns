{
  "name": "@interactive-os/apg-patterns",
  "version": "0.1.0",
  "description": "Serializable WAI-ARIA APG pattern definitions, runtime, and React adapters.",
  "keywords": [
    "aria",
    "wai-aria",
    "apg",
    "patterns",
    "react",
    "zod",
    "a11y"
  ],
  "license": "MIT",
  "author": "Interactive OS",
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=18.18"
  },
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.cjs",
    "./dist/core.js",
    "./dist/core.cjs",
    "./dist/react.js",
    "./dist/react.cjs"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs/proposals",
    "README.md",
    "API.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node scripts/normalize-dist-source-maps.mjs",
    "dev": "vite --config vite.config.ts",
    "demo": "vite --config vite.config.ts",
    "demo:build": "vite build --config vite.config.ts",
    "demo:preview": "vite preview --config vite.config.ts --host 127.0.0.1",
    "demo:smoke": "npm run demo:build && node scripts/smoke-demo-build.mjs && node scripts/smoke-demo-preview-server.mjs",
    "check": "npm run check:repo && npm run check:independence && npm run typecheck && npm test && npm run check:apg && npm run check:preset && npm run check:demo && npm run check:package && npm run check:react-peer && npm run build && npm run check:api && npm run check:exports && npm run check:readme && npm run check:publish && npm run smoke:package && npm run demo:smoke",
    "check:api": "node scripts/verify-api-reference.mjs",
    "update:api": "node scripts/verify-api-reference.mjs --write",
    "check:apg": "node scripts/verify-apg-example-coverage.mjs",
    "check:demo": "node scripts/verify-demo-consistency.mjs",
    "check:exports": "node scripts/verify-package-exports.mjs",
    "check:independence": "node scripts/verify-package-independence.mjs",
    "check:package": "node scripts/verify-package-side-effects.mjs",
    "check:publish": "node scripts/verify-publish-ready.mjs",
    "check:react-peer": "node scripts/verify-react-peer-compatibility.mjs",
    "check:repo": "node scripts/verify-repository-hygiene.mjs",
    "check:registry": "node scripts/verify-npm-registry-release.mjs",
    "check:readme": "node scripts/verify-readme-quick-start.mjs",
    "check:preset": "node scripts/verify-react-preset-surface.mjs",
    "prepublishOnly": "npm run release:check",
    "release:check": "npm run check && npm run check:registry",
    "smoke:package": "node scripts/smoke-package-consumer.mjs",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^29.1.1",
    "lucide-static": "^1.16.0",
    "postcss": "^8.5.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
